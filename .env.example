# LiveKit Credentials (https://cloud.livekit.io/)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Sarvam AI - STT & TTS for Indian languages incl. Kannada (https://dashboard.sarvam.ai/)
SARVAM_API_KEY=your_sarvam_key

# Deepgram - alternative STT & TTS, English-focused (https://console.deepgram.com/)
DEEPGRAM_API_KEY=your_deepgram_key

# LLM provider: "groq" or "gemini"
LLM_PROVIDER=groq

# Groq (LLM) - https://console.groq.com/  (free tier: 100k tokens/day per model)
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (generous free tier) - key from https://aistudio.google.com/apikey
# (must start with "AIzaSy..."). Set LLM_PROVIDER=gemini to use it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Vobiz / SIP Trunking Configuration
VOBIZ_SIP_TRUNK_ID=your_trunk_id
OUTBOUND_TRUNK_ID=your_trunk_id  # Usually same as above
VOBIZ_SIP_DOMAIN=your_sip_domain
VOBIZ_USERNAME=your_sip_username
VOBIZ_PASSWORD=your_sip_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# Speech providers: "sarvam" (multilingual: English/Hindi/Kannada) or "deepgram" (English)
TTS_PROVIDER=sarvam
STT_PROVIDER=sarvam
SARVAM_LANGUAGE=en-IN
SARVAM_VOICE=pooja
SARVAM_TTS_MODEL=bulbul:v3
